{
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "dist",
  "functions": {
    "api/[...path].js": {
      "includeFiles": "backend/{dist,node_modules/.prisma/client,node_modules/@prisma/client}/**"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
