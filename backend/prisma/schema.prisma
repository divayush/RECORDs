generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum DealStatus {
  PROFIT
  LOSS
  PENDING
}

model Deal {
  id             String     @id @default(auto()) @map("_id") @db.ObjectId
  dealAmount     Int
  holderFee      Int
  clientFee      Int
  serverFee      Int?       @default(0)
  holderUsername String
  clientUsername String?
  serverName     String?
  profit         Int        @default(0)
  loss           Int        @default(0)
  dealDate       DateTime
  status         DealStatus @default(PENDING)
  notes          String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@index([dealDate])
  @@index([status])
  @@index([holderUsername])
  @@index([clientUsername])
  @@index([serverName])
}

model DashboardCache {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  range      String   @unique
  data       Json
  computedAt DateTime @default(now())
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([expiresAt])
}

model UserProfile {
  id        String   @id @default("default") @map("_id")
  fullName  String
  email     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Spending {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  sentTo    String
  forWhat   String
  sentWhat  Int
  notes     String?
  spentAt   DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([spentAt])
  @@index([sentTo])
  @@index([forWhat])
}
