{
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "dist",
  "functions": {
    "api/[...path].js": {
      "includeFiles": [
        "backend/dist/**",
        "backend/node_modules/.prisma/client/**",
        "backend/node_modules/@prisma/client/**"
      ]
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
